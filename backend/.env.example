# ── MERIDIAN — Environment Configuration ──
# Copy this file to .env and fill in your values.

# Server
PORT=8000

# ADB — full path to your local adb executable
ADB_PATH=C:\path\to\adb.exe

# Auth credentials (mock login for demo)
AUTH_USERNAME=admin
AUTH_PASSWORD=your_password_here

# GitHub Pulse — target repo (owner/repo)
GITHUB_REPO=your-username/your-repo
